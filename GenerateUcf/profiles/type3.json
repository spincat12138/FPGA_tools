{
  "name": "type3",
  "description": "双列输出，只有 uxx，没有 uy，TestBlockB 的 Y 坐标偏移 2",
  "output": {
    "line_mode": "paired",
    "pair_padding": 64,
    "end_marker": "# End of constraints"
  },
  "modules": {
    "kind": "range",
    "template": "A[{i}].u",
    "start": 0,
    "stop": 25
  },
  "uxx": {
    "kind": "range",
    "start": 0,
    "stop": 23,
    "format": "u%02d"
  },
  "uy": {
    "kind": "none"
  },
  "path_template": "{module}/{block}/{uxx}/uRAM",
  "blocks": [
    {
      "name": "TestBlockA",
      "x_offset": 0,
      "y_offset": 0
    },
    {
      "name": "TestBlockB",
      "x_offset": 0,
      "y_offset": 2
    }
  ],
  "placement": {
    "x_base": 4,
    "x_jump": 6,
    "y_slice": 80,
    "y_jump": 4
  }
}
